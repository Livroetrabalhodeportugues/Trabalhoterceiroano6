<!DOCTYPE html>
<html lang="pt-pt">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Coral: Jornada Poética</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
    
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Cinzel:wght@400;700&family=Inter:wght@300;400;600;900&display=swap');
        
        :root {
            --paper: #fcfaf7;
            --ink: #1e293b;
            --gold: #b48c48;
            --bg-garden: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
            --bg-city: linear-gradient(135deg, #f1f5f9 0%, #cbd5e1 100%);
            --bg-beach: linear-gradient(135deg, #f0f9ff 0%, #bae6fd 100%);
        }

        body { 
            font-family: 'Inter', sans-serif; 
            background-color: var(--paper); 
            color: var(--ink);
            margin: 0;
            min-height: 100vh;
            background-image: url('https://www.transparenttextures.com/patterns/paper.png');
            transition: background 1.2s ease;
            overflow-x: hidden;
        }

        .serif { font-family: 'Libre Baskerville', serif; }
        .font-header { font-family: 'Cinzel', serif; letter-spacing: 0.15em; }

        .screen { display: none; min-height: 100vh; width: 100%; flex-direction: column; align-items: center; justify-content: center; padding: 20px; }
        .screen-active { display: flex; animation: fadeIn 0.5s ease-out; }

        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

        .btn-writer {
            background: var(--ink);
            color: white;
            padding: 1rem 2rem;
            border-radius: 0.5rem;
            font-family: 'Cinzel', serif;
            font-size: 0.75rem;
            transition: all 0.3s;
            cursor: pointer;
            border: 1px solid transparent;
        }
        .btn-writer:hover { background: transparent; color: var(--ink); border-color: var(--ink); }
        .btn-writer:disabled { opacity: 0.3; cursor: not-allowed; }

        .input-manuscript {
            background: transparent;
            border-bottom: 2px solid var(--ink);
            padding: 1rem;
            width: 100%;
            text-align: center;
            font-family: 'Libre Baskerville', serif;
            font-style: italic;
            font-size: 1.2rem;
            outline: none;
            margin-bottom: 2rem;
        }

        #board-container {
            display: grid;
            grid-template-columns: repeat(4, 1fr); 
            gap: 8px;
            max-width: 900px;
            margin: 20px auto;
            padding: 15px;
            background: rgba(255, 255, 255, 0.7);
            border-radius: 30px;
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255,255,255,0.9);
        }

        @media (min-width: 640px) { #board-container { grid-template-columns: repeat(6, 1fr); } }
        @media (min-width: 1024px) { #board-container { grid-template-columns: repeat(8, 1fr); } }

        .square {
            aspect-ratio: 1;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            background-size: cover;
            background-position: center;
            font-weight: 800;
            color: white;
            text-shadow: 0 2px 10px rgba(0,0,0,0.7);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            border: 1px solid rgba(255,255,255,0.4);
            box-shadow: inset 0 0 20px rgba(0,0,0,0.15);
        }

        .theme-garden { background-blend-mode: soft-light; background-color: #065f46; }
        .theme-city { background-blend-mode: multiply; background-color: #334155; }
        .theme-beach { background-blend-mode: overlay; background-color: #0369a1; }

        .player-pawn {
            width: 18px; height: 18px;
            border-radius: 50%;
            border: 2px solid white;
            box-shadow: 0 3px 8px rgba(0,0,0,0.4);
            transition: all 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
        }

        .dice-roll { animation: diceShake 0.6s infinite; }
        @keyframes diceShake {
            0% { transform: rotate(0) scale(1); }
            25% { transform: rotate(15deg) scale(1.1); }
            50% { transform: rotate(-15deg) scale(1.1); }
            100% { transform: rotate(0) scale(1); }
        }

        .modal { 
            display: none; position: fixed; inset: 0; 
            background: rgba(15, 23, 42, 0.9); backdrop-filter: blur(10px);
            z-index: 100; align-items: center; justify-content: center; padding: 20px;
        }
        .modal-active { display: flex; }

        .victory-card {
            background: white;
            padding: 3rem;
            border-radius: 3rem;
            text-align: center;
            max-width: 500px;
            width: 100%;
            box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5);
            animation: slideUp 0.6s ease-out;
        }

        @keyframes slideUp { from { transform: translateY(50px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
    </style>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-app.js";
        import { getAuth, signInAnonymously, onAuthStateChanged, signInWithCustomToken } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-auth.js";
        import { getFirestore, doc, setDoc, getDoc, onSnapshot, updateDoc } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js";

        const firebaseConfig = JSON.parse(__firebase_config);
        const app = initializeApp(firebaseConfig);
        const auth = getAuth(app);
        const db = getFirestore(app);
        const appId = typeof __app_id !== 'undefined' ? __app_id : 'default-app-id';

        const TOTAL_SQUARES = 48;
        const playerColors = ['#F43F5E', '#3B82F6', '#10B981', '#F59E0B', '#8B5CF6', '#EC4899'];
        
        const imgGarden = "https://images.unsplash.com/photo-1585320806297-9794b3e4eeae?auto=format&fit=crop&q=80&w=400";
        const imgCity = "https://images.unsplash.com/photo-1449824913935-59a10b8d2000?auto=format&fit=crop&q=80&w=400";
        const imgBeach = "https://images.unsplash.com/photo-1507525428034-b723cf961d3e?auto=format&fit=crop&q=80&w=400";

        const allQuestions = [
            { q: "Sophia nasceu em:", a: "Porto", o: ["Lisboa", "Porto", "Coimbra", "Faro"] },
            { q: "Além de escritora, Sophia foi:", a: "Deputada", o: ["Engenheira", "Pintora", "Deputada", "Presidente da República"] },
            { q: "Elemento muito presente nos poemas:", a: "Mar", o: ["Deserto", "Mar", "Neve", "Cidade"] },
            { q: "O livro Coral foi publicado em:", a: "1950", o: ["2000", "1950", "1980", "1930"] },
            { q: "Sophia faleceu em:", a: "2004", o: ["1990", "2004", "2010", "1985"] },
            { q: "O mar simboliza:", a: "Liberdade", o: ["Tristeza", "Liberdade", "Medo", "Guerra"] },
            { q: "A luz representa:", a: "Verdade", o: ["Escuridão", "Confusão", "Verdade", "Raiva"] },
            { q: "Ela viveu durante:", a: "Ditadura", o: ["Democracia plena", "Ditadura", "Monarquia", "Anarquia"] },
            { q: "O regime da época era:", a: "Estado Novo", o: ["República liberal", "Estado Novo", "Império", "Socialismo"] },
            { q: "O Estado Novo era:", a: "Autoritário", o: ["Democrático", "Autoritário", "Livre", "Moderno"] },
            { q: "Havia censura?", a: "Sim", o: ["Não", "Sim", "Só em jornais", "Só em músicas"] },
            { q: "A natureza nos poemas simboliza:", a: "Equilíbrio", o: ["Caos", "Equilíbrio", "Guerra", "Política direta"] },
            { q: "Sophia defendia:", a: "Liberdade", o: ["Ditadura", "Liberdade", "Violência", "Censura"] },
            { q: "Ela teve:", a: "5 filhos", o: ["1 filho", "3 filhos", "5 filhos", "Nenhum"] },
            { q: "Seu marido era:", a: "Jornalista", o: ["Médico", "Jornalista", "Professor", "Militar"] },
            { q: "A poesia dela é:", a: "Ética e simbólica", o: ["Só política", "Só romântica", "Ética e simbólica", "Científica"] },
            { q: "Ela morreu em:", a: "Lisboa", o: ["Porto", "Lisboa", "Paris", "Madrid"] },
            { q: "A obra busca:", a: "Ordem e harmonia", o: ["Confusão", "Ordem e harmonia", "Violência", "Humor"] },
            { q: "Quantos anos durou a ditadura Salazar?", a: "41 anos", o: ["41 anos", "38 anos", "40 anos", "29 anos"] },
            { q: "O contexto do livro está ligado a:", a: "Ditadura portuguesa", o: ["Revolução Industrial", "Ditadura portuguesa", "Idade Média", "Guerra Fria direta"] },
            { q: "A poesia funcionava como:", a: "Resistência indireta", o: ["Propaganda", "Resistência indireta", "Entretenimento vazio", "Jornalismo"] },
            { q: "Autores usavam linguagem simbólica para:", a: "Evitar censura", o: ["Confundir leitores", "Evitar censura", "Ficar famosos", "Imitar outros"] },
            { q: "Após a Segunda Guerra Mundial, a Europa estava:", a: "Em crise moral e material", o: ["Rica", "Em crise moral e material", "Estável", "Sem conflitos"] },
            { q: "A poesia de Sophia busca:", a: "Harmonia ideal", o: ["Desordem", "Harmonia ideal", "Tecnologia", "Política direta"] },
            { q: "A natureza nos poemas:", a: "Tem significado simbólico", o: ["É decorativa", "Tem significado simbólico", "Não aparece", "É urbana"] },
            { q: "A sociedade portuguesa era:", a: "Controlada e conservadora", o: ["Livre", "Controlada e conservadora", "Revolucionária", "Moderna"] },
            { q: "A igreja tinha:", a: "Grande influência", o: ["Nenhuma influência", "Grande influência", "Influência pequena", "Apenas política"] },
            { q: "A desigualdade social era:", a: "Alta", o: ["Inexistente", "Alta", "Baixa", "Controlada"] },
            { q: "A obra de Sophia tem compromisso:", a: "Moral e humano", o: ["Comercial", "Moral e humano", "Militar", "Científico"] },
            { q: "A crítica política nos poemas ocorre:", a: "Indiretamente por símbolos", o: ["Diretamente", "Indiretamente por símbolos", "Apenas em entrevistas", "Não ocorre"] },
            { q: "A “harmonia” representa:", a: "Mundo ideal desejado", o: ["Mundo real", "Mundo ideal desejado", "Guerra", "Ditadura"] },
            { q: "A natureza contrasta com:", a: "Repressão da ditadura", o: ["Beleza", "Repressão da ditadura", "Arte", "Literatura"] },
            { q: "A poesia de Sophia pode ser vista como:", a: "Ética e crítica", o: ["Alienada", "Ética e crítica", "Técnica", "Científica"] },
            { q: "O uso de símbolos permite:", a: "Driblar censura", o: ["Evitar leitura", "Driblar censura", "Simplificar ideias", "Esconder erros"] },
            { q: "A obra propõe:", a: "Transformar valores humanos", o: ["Aceitar realidade", "Transformar valores humanos", "Ignorar sociedade", "Evitar política"] },
            { q: "O contexto influencia a obra:", a: "Muito", o: ["Pouco", "Muito", "Nada", "Só na forma"] },
            { q: "A literatura da época tinha função:", a: "Social e moral", o: ["Apenas estética", "Social e moral", "Comercial", "Científica"] }
        ];

        let user = null;
        let userNick = "";
        let currentRoomId = null;
        let roomData = null;
        let unsubscribeRoom = null;
        let usedQuestionIndexes = [];
        let victoryTriggered = false;

        const initAuth = async () => {
            if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
                await signInWithCustomToken(auth, __initial_auth_token);
            } else {
                await signInAnonymously(auth);
            }
        };
        initAuth();
        onAuthStateChanged(auth, (u) => { user = u; });

        window.showScreen = (id) => {
            document.querySelectorAll('.screen').forEach(s => s.classList.remove('screen-active'));
            document.getElementById(id).classList.add('screen-active');
        };

        window.saveNick = () => {
            const val = document.getElementById('input-nick').value.trim();
            if (!val) return;
            userNick = val;
            window.showScreen('screen-lobby');
        };

        const getRoomRef = (id) => doc(db, 'artifacts', appId, 'public', 'data', 'rooms', id);

        window.createRoom = async () => {
            const id = Math.floor(1000 + Math.random() * 9000).toString();
            await setDoc(getRoomRef(id), {
                id, hostId: user.uid, status: 'waiting',
                players: [{ uid: user.uid, name: userNick, pos: 0, color: playerColors[0] }],
                currentTurnIndex: 0, usedQuestions: [], winnerName: null, lastUpdate: Date.now()
            });
            joinRoom(id);
        };

        window.openJoinModal = () => { document.getElementById('modal-join').classList.add('modal-active'); };
        window.closeJoinModal = () => { document.getElementById('modal-join').classList.remove('modal-active'); };
        window.tryJoinRoom = async () => {
            const id = document.getElementById('input-code').value.trim();
            const snap = await getDoc(getRoomRef(id));
            if (snap.exists() && snap.data().players.length < 6) joinRoom(id);
        };

        function joinRoom(id) {
            currentRoomId = id;
            if (unsubscribeRoom) unsubscribeRoom();
            unsubscribeRoom = onSnapshot(getRoomRef(id), (snap) => {
                roomData = snap.data();
                if (!roomData) return;
                
                const myData = roomData.players.find(p => p.uid === user.uid);
                if (!myData && roomData.status === 'waiting') {
                    const players = [...roomData.players, { 
                        uid: user.uid, name: userNick, pos: 0, 
                        color: playerColors[roomData.players.length] 
                    }];
                    updateDoc(getRoomRef(id), { players });
                }
                usedQuestionIndexes = roomData.usedQuestions || [];
                syncUI();
            }, (err) => console.error("Firestore error:", err));
            window.showScreen('screen-waiting');
        }

        function syncUI() {
            if (roomData.status === 'finished') {
                showVictoryScreen(roomData.winnerName);
                return;
            }

            if (roomData.status === 'waiting') {
                document.getElementById('room-code-display').innerText = roomData.id;
                document.getElementById('players-list').innerHTML = roomData.players.map(p => `
                    <div class="flex items-center gap-3 p-3 border-b border-slate-100 serif italic">
                        <div class="w-3 h-3 rounded-full" style="background:${p.color}"></div>
                        <span>${p.name}</span>
                    </div>
                `).join('');
                if (roomData.hostId === user.uid) {
                    const btn = document.getElementById('btn-start-game');
                    btn.style.display = 'block';
                    btn.onclick = () => updateDoc(getRoomRef(currentRoomId), { status: 'playing' });
                }
            } else if (roomData.status === 'playing') {
                if (!document.getElementById('screen-game').classList.contains('screen-active')) {
                    window.showScreen('screen-game');
                    initBoard();
                }
                renderBoard();
            }
        }

        function initBoard() {
            const board = document.getElementById('board-container');
            board.innerHTML = '';
            for (let i = 0; i < TOTAL_SQUARES; i++) {
                const div = document.createElement('div');
                div.id = `sq-${i}`;
                let theme, img;
                if (i < 16) { theme = "theme-garden"; img = imgGarden; }
                else if (i < 32) { theme = "theme-city"; img = imgCity; }
                else { theme = "theme-beach"; img = imgBeach; }
                
                div.className = `square ${theme} ${i === 0 ? 'border-amber-500 border-2' : ''}`;
                div.style.backgroundImage = `url('${img}')`;
                div.innerHTML = `
                    <span class="absolute top-1 left-1 opacity-40 text-[9px] font-black">${i + 1}</span>
                    <div id="pawns-${i}" class="flex flex-wrap gap-0.5 justify-center items-center w-full h-full p-1"></div>
                `;
                board.appendChild(div);
            }
        }

        function renderBoard() {
            for (let i = 0; i < TOTAL_SQUARES; i++) {
                const pContainer = document.getElementById(`pawns-${i}`);
                if (pContainer) pContainer.innerHTML = '';
            }
            
            roomData.players.forEach(p => {
                const pawn = document.createElement('div');
                pawn.className = 'player-pawn';
                pawn.style.backgroundColor = p.color;
                const target = document.getElementById(`pawns-${p.pos}`);
                if (target) target.appendChild(pawn);
            });

            const currentP = roomData.players[roomData.currentTurnIndex];
            const isMyTurn = currentP.uid === user.uid;
            
            const turnText = document.getElementById('player-name-display');
            turnText.innerText = isMyTurn ? `Tua vez, ${currentP.name}` : `Aguardando ${currentP.name}...`;
            turnText.style.color = currentP.color;
            
            const rollBtn = document.getElementById('roll-btn');
            rollBtn.disabled = !isMyTurn;
            rollBtn.style.opacity = isMyTurn ? "1" : "0.5";

            const pos = currentP.pos;
            if (pos < 16) document.body.style.background = "var(--bg-garden)";
            else if (pos < 32) document.body.style.background = "var(--bg-city)";
            else document.body.style.background = "var(--bg-beach)";
        }

        window.rollDice = () => {
            const dice = document.getElementById('dice-display');
            dice.classList.add('dice-roll');
            let roll = 0, count = 0;
            const timer = setInterval(() => {
                roll = Math.floor(Math.random() * 6) + 1;
                dice.innerText = roll;
                if (count++ > 12) {
                    clearInterval(timer);
                    dice.classList.remove('dice-roll');
                    setTimeout(() => pickQuestion(roll), 600);
                }
            }, 70);
        };

        function pickQuestion(roll) {
            let available = allQuestions
                .map((q, idx) => ({ ...q, idx }))
                .filter(q => !usedQuestionIndexes.includes(q.idx));

            if (available.length === 0) {
                usedQuestionIndexes = [];
                available = allQuestions.map((q, idx) => ({ ...q, idx }));
            }

            const qObj = available[Math.floor(Math.random() * available.length)];
            showQuestionModal(qObj, roll);
        }

        function showQuestionModal(qObj, roll) {
            document.getElementById('question-modal').classList.add('modal-active');
            document.getElementById('question-text').innerText = qObj.q;
            const container = document.getElementById('options-container');
            container.innerHTML = '';
            
            const shuffledOptions = [...qObj.o].sort(() => Math.random() - 0.5);

            shuffledOptions.forEach(opt => {
                const b = document.createElement('button');
                b.className = "w-full p-4 text-left border-2 border-slate-100 rounded-xl hover:border-slate-900 transition-all serif italic text-slate-800 bg-white/80 active:scale-95";
                b.innerText = opt;
                b.onclick = async () => {
                    document.getElementById('question-modal').classList.remove('modal-active');
                    const isCorrect = opt === qObj.a;
                    
                    const players = JSON.parse(JSON.stringify(roomData.players));
                    let someoneWon = false;
                    let winnerName = null;

                    if (isCorrect) {
                        players[roomData.currentTurnIndex].pos = Math.min(TOTAL_SQUARES - 1, players[roomData.currentTurnIndex].pos + roll);
                        if (players[roomData.currentTurnIndex].pos >= TOTAL_SQUARES - 1) {
                            someoneWon = true;
                            winnerName = players[roomData.currentTurnIndex].name;
                        }
                    }

                    const nextTurn = (roomData.currentTurnIndex + 1) % players.length;
                    const newUsed = [...usedQuestionIndexes, qObj.idx];
                    
                    showFeedback(isCorrect, qObj.a, async () => {
                        await updateDoc(getRoomRef(currentRoomId), {
                            players,
                            currentTurnIndex: nextTurn,
                            usedQuestions: newUsed,
                            status: someoneWon ? 'finished' : 'playing',
                            winnerName: winnerName || null,
                            lastUpdate: Date.now()
                        });
                    });
                };
                container.appendChild(b);
            });
        }

        function showFeedback(success, correct, callback) {
            const modal = document.getElementById('feedback-modal');
            modal.classList.add('modal-active');
            
            const title = document.getElementById('feedback-title');
            const icon = document.getElementById('feedback-icon');
            const msg = document.getElementById('feedback-message');
            const correctDiv = document.getElementById('correct-answer-display');

            if (success) {
                icon.innerText = "🌊";
                title.innerText = "Luz Plena!";
                title.className = "text-3xl font-black text-emerald-600 font-header";
                msg.innerText = "Tua leitura é clara como o dia do mar.";
                correctDiv.classList.add('hidden');
                confetti({ particleCount: 100, spread: 70, origin: { y: 0.6 } });
            } else {
                icon.innerText = "🏛️";
                title.innerText = "Ruína!";
                title.className = "text-3xl font-black text-rose-600 font-header";
                msg.innerText = "A sombra da dúvida impediu o teu avanço.";
                document.getElementById('correct-text').innerText = `Resposta: ${correct}`;
                correctDiv.classList.remove('hidden');
            }

            document.getElementById('close-feedback').onclick = () => {
                modal.classList.remove('modal-active');
                callback();
            };
        }

        function showVictoryScreen(name) {
            if (victoryTriggered) return;
            victoryTriggered = true;

            const modal = document.getElementById('victory-modal');
            modal.classList.add('modal-active');
            document.getElementById('winner-name').innerText = name;

            const duration = 15 * 1000;
            const animationEnd = Date.now() + duration;
            const defaults = { startVelocity: 30, spread: 360, ticks: 60, zIndex: 0 };

            const randomInRange = (min, max) => Math.random() * (max - min) + min;

            const interval = setInterval(function() {
                const timeLeft = animationEnd - Date.now();
                if (timeLeft <= 0) return clearInterval(interval);

                const particleCount = 50 * (timeLeft / duration);
                confetti({ ...defaults, particleCount, origin: { x: randomInRange(0.1, 0.3), y: Math.random() - 0.2 } });
                confetti({ ...defaults, particleCount, origin: { x: randomInRange(0.7, 0.9), y: Math.random() - 0.2 } });
            }, 250);
        }

        window.backToLobby = () => {
            location.reload();
        };

    </script>
</head>
<body>

    <!-- TELA 1: LOGIN -->
    <div id="screen-login" class="screen screen-active">
        <div class="text-center max-w-sm w-full px-6">
            <h1 class="font-header text-5xl mb-2">CORAL</h1>
            <p class="serif italic text-slate-400 mb-12">"Digo o nome das coisas para as libertar"</p>
            <input type="text" id="input-nick" placeholder="O teu nome de escritor..." class="input-manuscript">
            <button onclick="saveNick()" class="btn-writer w-full">INICIAR JORNADA</button>
        </div>
    </div>

    <!-- TELA 2: LOBBY -->
    <div id="screen-lobby" class="screen">
        <div class="w-full max-w-sm">
            <h2 class="font-header text-2xl text-center mb-10">O ESCRITÓRIO</h2>
            <div class="grid grid-cols-1 gap-4">
                <div onclick="createRoom()" class="p-8 border border-slate-200 rounded-3xl bg-white/80 text-center cursor-pointer hover:shadow-xl transition group">
                    <span class="text-4xl group-hover:scale-125 inline-block transition">🖋️</span>
                    <h3 class="font-header text-xs mt-4">NOVA OBRA (CRIAR SALA)</h3>
                </div>
                <div onclick="openJoinModal()" class="p-8 border border-slate-200 rounded-3xl bg-white/80 text-center cursor-pointer hover:shadow-xl transition group">
                    <span class="text-4xl group-hover:scale-125 inline-block transition">🐚</span>
                    <h3 class="font-header text-xs mt-4">LER JUNTO (ENTRAR)</h3>
                </div>
            </div>
        </div>
    </div>

    <!-- TELA 3: ESPERA -->
    <div id="screen-waiting" class="screen">
        <div class="bg-white p-10 rounded-[2.5rem] border border-slate-100 shadow-2xl w-full max-w-xs text-center">
            <p class="font-header text-[10px] mb-2 text-gold">CÓDIGO DA SALA</p>
            <div id="room-code-display" class="font-header text-5xl mb-8 tracking-tighter">----</div>
            <div id="players-list" class="mb-8 text-left max-h-48 overflow-y-auto"></div>
            <button id="btn-start-game" style="display:none" class="btn-writer w-full mb-4">COMEÇAR NAVEGAÇÃO</button>
            <p class="serif italic text-xs text-slate-400">Aguardando o autor iniciar a obra...</p>
        </div>
    </div>

    <!-- TELA 4: JOGO -->
    <div id="screen-game" class="screen !justify-start !pt-8">
        <div class="max-w-6xl w-full grid grid-cols-1 lg:grid-cols-4 gap-8">
            
            <div class="lg:col-span-1 space-y-6">
                <header>
                    <h1 class="font-header text-3xl font-black">Sophia</h1>
                    <p class="serif italic text-slate-500 text-sm mt-1">“Divido o dia em duas partes...”</p>
                </header>

                <div class="bg-white/80 p-6 rounded-3xl border-2 border-slate-100 shadow-sm">
                    <p class="text-[9px] uppercase tracking-widest font-black opacity-40 mb-1">Vez do Intérprete</p>
                    <h2 id="player-name-display" class="font-header text-xl">Aguardando...</h2>
                </div>

                <div class="flex items-center gap-4">
                    <div id="dice-display" class="w-20 h-20 bg-slate-900 text-white rounded-2xl flex items-center justify-center text-4xl font-header shadow-xl">?</div>
                    <button id="roll-btn" onclick="rollDice()" class="flex-1 py-6 bg-slate-900 text-white font-header rounded-2xl transition-all shadow-xl active:scale-95 disabled:opacity-30">
                        LANÇAR DADO
                    </button>
                </div>
            </div>

            <div class="lg:col-span-3">
                <div id="board-container"></div>
            </div>
        </div>
    </div>

    <!-- MODAL DE ENTRAR -->
    <div id="modal-join" class="modal">
        <div class="bg-white p-10 rounded-[2.5rem] w-full max-w-sm text-center">
            <h3 class="font-header mb-6">CÓDIGO DA OBRA</h3>
            <input type="text" id="input-code" placeholder="0000" class="input-manuscript !text-4xl !mb-8">
            <button onclick="tryJoinRoom()" class="btn-writer w-full mb-4">ENTRAR</button>
            <button onclick="closeJoinModal()" class="text-[10px] font-bold opacity-30 uppercase tracking-widest">CANCELAR</button>
        </div>
    </div>

    <!-- MODAL DE PERGUNTA -->
    <div id="question-modal" class="modal">
        <div class="bg-white rounded-[2.5rem] max-w-xl w-full p-8 md:p-12 shadow-2xl">
            <p class="font-header text-[10px] text-gold mb-4">DESAFIO LITERÁRIO</p>
            <h3 id="question-text" class="serif text-xl md:text-2xl font-bold text-slate-900 mb-8 leading-relaxed">...</h3>
            <div id="options-container" class="grid grid-cols-1 gap-3"></div>
        </div>
    </div>

    <!-- MODAL DE FEEDBACK -->
    <div id="feedback-modal" class="modal">
        <div class="bg-white rounded-[2.5rem] p-10 text-center max-w-sm w-full shadow-2xl">
            <div id="feedback-icon" class="text-7xl mb-4"></div>
            <h2 id="feedback-title" class="mb-2"></h2>
            <p id="feedback-message" class="serif italic text-slate-500 mb-8"></p>
            <div id="correct-answer-display" class="hidden mb-8 p-4 bg-rose-50 border border-rose-100 rounded-2xl text-left">
                <p id="correct-text" class="text-slate-800 font-bold text-sm"></p>
            </div>
            <button id="close-feedback" class="btn-writer w-full">PROSSEGUIR</button>
        </div>
    </div>

    <!-- MODAL DE VITÓRIA (EXIBE PARA TODOS) -->
    <div id="victory-modal" class="modal">
        <div class="victory-card">
            <div class="text-6xl mb-6">👑</div>
            <h1 class="font-header text-4xl mb-2 text-slate-900">VITÓRIA!</h1>
            <p class="serif italic text-slate-500 mb-6">"Pela primeira vez a luz é inteira"</p>
            <div class="py-4 border-y border-slate-100 mb-8">
                <h2 id="winner-name" class="font-header text-3xl text-gold">...</h2>
                <p class="text-[10px] uppercase tracking-widest mt-2 font-bold opacity-40">Alcançou a Harmonia Plena</p>
            </div>
            <button onclick="backToLobby()" class="btn-writer w-full">VOLTAR AO LOBBY</button>
        </div>
    </div>

</body>
</html>
